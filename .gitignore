# Node dependencies
**/node_modules/

# Build output
client/dist/

# Environment files
server/.env
client/.env
.venv/
server/.venv/

# Python cache
server/__pycache__/
server/.pytest_cache/
server/*.pyc

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
server/tmp/*
!server/tmp/.gitkeep
